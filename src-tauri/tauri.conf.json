{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "JSON XML 格式化工具",
  "version": "0.1.0",
  "identifier": "com.codex.jsonxmlformatter",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "开发者文本工具箱",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
